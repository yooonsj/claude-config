{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "deny": [
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git force:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Bash(docker system prune:*)",
      "Bash(kubectl delete:*)",
      "Bash(helm uninstall:*)",
      "Bash(npm install -g:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)",
      "Bash(defaults write:*)",
      "Bash(launchctl:*)",
      "Bash(networksetup:*)",
      "Read(.env)",
      "Read(.env.*)"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node /Users/ivan/.claude/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "oh-my-claudecode@omc": true,
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "python-development@claude-code-workflows": true,
    "claude-md-management@claude-plugins-official": true,
    "data-engineering@claude-code-workflows": true,
    "codex@dexp-ai-toolkits": true,
    "example-skills@anthropic-agent-skills": true
  },
  "extraKnownMarketplaces": {
    "dexp-ai-toolkits": {
      "source": {
        "source": "git",
        "url": "https://github.com/MP-DeXP/DeXP-AI-Toolkits.git"
      },
      "autoUpdate": true
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "attribution": {
    "commits": true,
    "pullRequests": true
  },
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "MCP_TIMEOUT": "30000"
  },
  "enableAllProjectMcpServers": false
}
