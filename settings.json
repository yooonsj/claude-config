{
  "env": {
    "BASH_DEFAULT_TIMEOUT_MS": "60000",
    "MCP_TIMEOUT": "30000",
    "ECC_HOOK_PROFILE": "standard",
    "ECC_DISABLED_HOOKS": "session:start",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_PROMPT_CACHING_1H": "true",
    "FORCE_PROMPT_CACHING_5M": "false",
    "CLAUDE_CODE_ENABLE_AWAY_SUMMARY": "true"
  },
  "attribution": {},
  "permissions": {
    "deny": [
      "Bash(mkfs:*)",
      "Bash(dd:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)"
    ],
    "ask": [
      "Bash(rm -rf:*)",
      "Bash(rm -r:*)",
      "Bash(sudo:*)",
      "Bash(chmod:*)",
      "Bash(chown:*)",
      "Bash(kill:*)",
      "Bash(killall:*)",
      "Bash(pkill:*)",
      "Bash(ssh:*)",
      "Bash(scp:*)",
      "Bash(curl:*)",
      "Bash(wget:*)",
      "Bash(git push:*)",
      "Bash(git reset --hard:*)",
      "Bash(git clean:*)",
      "Bash(git force:*)",
      "Bash(docker rm:*)",
      "Bash(docker rmi:*)",
      "Bash(docker system prune:*)",
      "Bash(kubectl delete:*)",
      "Bash(helm uninstall:*)",
      "Bash(npm install -g:*)",
      "Bash(brew install:*)",
      "Bash(brew uninstall:*)",
      "Bash(defaults write:*)",
      "Bash(launchctl:*)",
      "Bash(networksetup:*)",
      "Read(.env)",
      "Read(.env.*)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "model": "sonnet",
  "enableAllProjectMcpServers": false,
  "statusLine": {
    "type": "command",
    "command": "bash -c 'plugin_dir=$(ls -d \"${CLAUDE_CONFIG_DIR:-$HOME/.claude}\"/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | awk -F/ '\"'\"'{ print $(NF-1) \"\\t\" $(0) }'\"'\"' | sort -t. -k1,1n -k2,2n -k3,3n -k4,4n | tail -1 | cut -f2-); exec \"/Users/ivan/.bun/bin/bun\" --env-file /dev/null \"${plugin_dir}src/index.ts\"'"
  },
  "enabledPlugins": {
    "context7@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "python-development@claude-code-workflows": true,
    "claude-md-management@claude-plugins-official": true,
    "data-engineering@claude-code-workflows": true,
    "example-skills@anthropic-agent-skills": true,
    "superpowers@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "claude-hud@claude-hud": true,
    "telegram@claude-plugins-official": true,
    "everything-claude-code@everything-claude-code": true,
    "codex@openai-codex": true,
    "skills-cleaner@skills-cleaner": true
  },
  "extraKnownMarketplaces": {
    "dexp-ai-toolkits": {
      "source": {
        "source": "git",
        "url": "https://github.com/MP-DeXP/DeXP-AI-Toolkits.git"
      },
      "autoUpdate": true
    },
    "anthropic-agent-skills": {
      "source": {
        "source": "github",
        "repo": "anthropics/skills"
      }
    },
    "claude-hud": {
      "source": {
        "source": "github",
        "repo": "jarrodwatts/claude-hud"
      }
    },
    "everything-claude-code": {
      "source": {
        "source": "github",
        "repo": "affaan-m/everything-claude-code"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "skills-cleaner": {
      "source": {
        "source": "github",
        "repo": "amebahead/skills-cleaner"
      }
    }
  },
  "skipDangerousModePermissionPrompt": true,
  "remoteControlAtStartup": true,
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/ivan/.claude/hooks/rtk-rewrite.sh"
          }
        ]
      }
    ]
  }
}